package ex8;

import java.util.*;

public class Exercicio8 {
    public static void main(String[] args) {
        // Exercício 8: Análise de Frequência de Pedidos no Delivery

        Scanner scanner = new Scanner(System.in);
        List<Integer> pedidos = new ArrayList<>();

        System.out.println("=== Análise de Pedidos - Delivery ===");
        System.out.print("Quantos pedidos deseja registrar? ");
        int quantidade = scanner.nextInt();

        System.out.println("Digite os códigos dos pedidos:");
        for (int i = 1; i <= quantidade; i++) {
            System.out.print("Pedido " + i + ": ");
            pedidos.add(scanner.nextInt());
        }

        // Contagem de frequência
        Map<Integer, Integer> frequencia = new HashMap<>();
        for (int codigo : pedidos) {
            frequencia.put(codigo, frequencia.getOrDefault(codigo, 0) + 1);
        }

        // Encontrar o mais repetido
        int codigoMaisRepetido = -1;
        int maxFreq = 0;
        for (Map.Entry<Integer, Integer> entry : frequencia.entrySet()) {
            if (entry.getValue() > maxFreq) {
                maxFreq = entry.getValue();
                codigoMaisRepetido = entry.getKey();
            }
        }

        System.out.println("\n=== Resultado ===");
        System.out.println("Frequência de cada item:");
        for (Map.Entry<Integer, Integer> entry : frequencia.entrySet()) {
            System.out.println("  Código " + entry.getKey() + " → " + entry.getValue() + "x");
        }
        System.out.println("\nItem mais pedido: Código " + codigoMaisRepetido + " (" + maxFreq + " pedidos)");

        scanner.close();
    }
}
